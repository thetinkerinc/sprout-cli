	},
	"peerDependencies": {
		"typescript": "^6.0.3"
	},
	"dependencies": {
		"@inquirer/prompts": "^8.4.2",
		"commander": "^14.0.3",
		"radashi": "^12.9.0",
		"shelljs": "^0.10.0",
		"shelljs-live": "^0.0.5",
		"signal-exit": "^4.1.0"
