{
	"name": "sprt",
	"version": "0.1.3",
	"license": "MIT",
	"type": "module",
	"description": "CLI for managing a Sprout app",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"scripts": {
		"dev": "tsc --watch",
		"build": "tsc",
		"prepare": "chmod +x ./dist/index.js",
		"upload": "npm publish --access=public",
		"release": "run-s build prepare upload"
	},
	"bin": {
		"sprt": "dist/index.js"
	},
	"files": [
		"dist"
	],
	"devDependencies": {
		"@types/bun": "^1.3.13",
		"@types/node": "^25.6.1",
		"@types/shelljs": "^0.10.0",
		"npm-run-all": "^4.1.5"
	},
	"peerDependencies": {
		"typescript": "^6.0.3"
	},
	"dependencies": {
		"@inquirer/prompts": "^8.4.2",
		"commander": "^14.0.3",
		"radashi": "^12.9.0",
		"shelljs": "^0.10.0",
		"shelljs-live": "^0.0.5",
		"signal-exit": "^4.1.0"
	}
}
